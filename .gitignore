# Virtual Environments
.venv/
venv/
ENV/
runtime/
bin/
include/
lib/
lib64/
share/
pyvenv.cfg

# Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.coverage
htmlcov/
